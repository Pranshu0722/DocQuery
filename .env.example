# Copy this file to `.env` and adjust the values.
# All variables are optional — the app has sensible defaults.

# Which Ollama model to use. Make sure you have pulled it with `ollama pull <model>`.
# Examples: tinyllama, mistral, phi3:mini, llama3.2:1b, gemma2:2b
OLLAMA_MODEL=tinyllama

# Where Ollama is running. Defaults to localhost; the app auto-switches to
# host.docker.internal:11434 when running inside Docker.
# OLLAMA_URL=http://localhost:11434

# Path to the Tesseract OCR binary. Only needed on Windows if Tesseract
# isn't on your system PATH. Leave unset on Linux/macOS.
# TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
